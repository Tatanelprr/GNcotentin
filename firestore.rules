rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // News : lecture publique, écriture admin uniquement
    match /news/{newsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Événements : lecture publique, écriture admin uniquement
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Galerie : lecture publique, écriture admin uniquement
    match /galerie/{albumId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Visites : tout le monde peut enregistrer, seul l'admin peut lire
    match /visits/{day} {
      allow write: if true;
      allow read: if request.auth != null;
    }

  }
}
